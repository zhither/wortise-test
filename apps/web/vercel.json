{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && NODE_ENV=development pnpm install",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://wortise-test-api.vercel.app/api/:path*"
    },
    {
      "source": "/trpc/:path*",
      "destination": "https://wortise-test-api.vercel.app/trpc/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
