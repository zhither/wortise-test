NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/wortise_dev
# En auth.ts el adaptador Mongo usa transaction:false (compatible con Mongo local).
# Con replica set / Atlas podés valorar activar transacciones en el código si lo necesitás.
BETTER_AUTH_SECRET=change-me-min-16-chars-long-secret
BETTER_AUTH_URL=http://localhost:3000
# Una URL o varias separadas por coma (prod + preview Vercel, etc.)
CORS_ORIGIN=http://localhost:5173

# Chat LLM: Vertex (Gemini). En desarrollo, por defecto va en mock salvo LLM_MOCK=0.
# Producción: credenciales Vertex abajo, o LLM_MOCK=1 (demo sin modelo remoto).
# LLM_MOCK=0

# Google Vertex AI — credenciales del service account (no subir el JSON al repo)
# GOOGLE_VERTEX_PROJECT=wortise
# GOOGLE_VERTEX_LOCATION=us-central1
# GOOGLE_CLIENT_EMAIL=xxx@wortise.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# VERTEX_GEMINI_MODEL=gemini-2.0-flash-001

# Clima: en desarrollo es mock por defecto. Para Open-Meteo real en local:
# WEATHER_USE_MOCK=0
